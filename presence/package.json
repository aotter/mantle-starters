{
  "name": "mantle-starter-presence",
  "version": "0.0.11-alpha.16",
  "private": true,
  "description": "Presence starter for mantle v0.1.0 — landing page and secondary pages. Optional contact form behavior is installed through the contact feature overlay. No article list. Runs on wrangler dev with local D1 + KV.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/wrangler-dev.mjs",
    "fixture": "tsx test/fixture/apply-dev.ts",
    "validate": "mantle validate",
    "validate:deploy": "mantle validate --phase deploy",
    "mantle:prompt": "node scripts/mantle.mjs prompt",
    "introspect": "mantle introspect",
    "emit-openapi": "mantle emit-openapi > openapi.json",
    "emit-types": "mantle emit-types --namespace PresenceCms > mantle-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "pnpm validate:deploy && pnpm typecheck && wrangler deploy",
    "setup:site": "node scripts/setup-site.mjs",
    "provision:plan": "node scripts/provision.mjs plan",
    "provision:up": "node scripts/provision.mjs up",
    "theme:fork": "node scripts/theme-fork.mjs",
    "theme:reset": "node scripts/theme-reset.mjs"
  },
  "dependencies": {
    "@aotter/mantle": "0.0.11-alpha.16",
    "@cloudflare/workers-oauth-provider": "catalog:",
    "aws4fetch": "catalog:",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "marked": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aotter/mantle-spec": "0.0.11-alpha.16",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
