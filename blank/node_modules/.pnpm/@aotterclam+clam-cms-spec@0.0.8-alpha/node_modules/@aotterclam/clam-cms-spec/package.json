{
  "name": "@aotterclam/clam-cms-spec",
  "version": "0.0.8-alpha",
  "description": "Spec engine for clam-cms: types + manifest YAML parse + validate + diagnostics + JSON-Schema → zod converter + CLI. Zero env / adapter deps.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/clam-cms/tree/main/packages/clam-cms-spec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/clam-cms.git",
    "directory": "packages/clam-cms-spec"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clam-cms": "./dist/infrastructure/cli/ClamCmsCli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "yaml": "^2.6.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  }
}