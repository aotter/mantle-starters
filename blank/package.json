{
  "name": "clam-mantle-starter-blank",
  "version": "0.0.8-alpha",
  "private": true,
  "description": "Headless CMS starter for clam-mantle \u2014 API + MCP only, no public HTML rendering. Bring your own frontend.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "validate": "clam-mantle validate",
    "mantle:prompt": "node scripts/mantle.mjs prompt",
    "introspect": "clam-mantle introspect",
    "emit-openapi": "clam-mantle emit-openapi > openapi.json",
    "emit-types": "clam-mantle emit-types --namespace BlankCms > clam-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "wrangler deploy",
    "setup:site": "node scripts/setup-site.mjs"
  },
  "dependencies": {
    "@aotterclam/clam-mantle": "0.0.10-alpha",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}