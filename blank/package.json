{
  "name": "clam-cms-starter-blank",
  "version": "0.0.8-alpha",
  "private": true,
  "description": "Headless CMS starter for clam-cms — API + MCP only, no public HTML rendering. Bring your own frontend.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "validate": "clam-cms validate",
    "introspect": "clam-cms introspect",
    "emit-openapi": "clam-cms emit-openapi > openapi.json",
    "emit-types": "clam-cms emit-types --namespace BlankCms > clam-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "wrangler deploy",
    "setup:site": "node scripts/setup-site.mjs"
  },
  "dependencies": {
    "@aotterclam/clam-cms-spec": "0.0.8-alpha",
    "@aotterclam/clam-cms-runtime": "0.0.8-alpha",
    "@aotterclam/clam-cms-cloudflare": "0.0.8-alpha",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "wrangler": "^3.103.2"
  }
}
