{
  "name": "mantle-starter-blank",
  "version": "0.0.7-alpha",
  "private": true,
  "description": "Headless CMS starter for mantle — API + MCP only, no public HTML rendering. Bring your own frontend.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "validate": "mantle validate",
    "introspect": "mantle introspect",
    "emit-openapi": "mantle emit-openapi > openapi.json",
    "emit-types": "mantle emit-types --namespace BlankCms > mantle-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "wrangler deploy",
    "setup:site": "node scripts/setup-site.mjs"
  },
  "dependencies": {
    "@aotter/mantle-spec": "0.0.7-alpha",
    "@aotter/mantle-runtime": "0.0.7-alpha",
    "@aotter/mantle-cloudflare": "0.0.7-alpha",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "wrangler": "^3.103.2"
  }
}
