{
  "name": "mantle-starter-blank",
  "version": "0.0.11-alpha.35",
  "private": true,
  "description": "Headless CMS starter for mantle — API + MCP only, no public HTML rendering. Bring your own frontend.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/wrangler-dev.mjs",
    "validate": "mantle validate",
    "validate:deploy": "mantle validate --phase deploy",
    "mantle:update": "node scripts/update.mjs",
    "introspect": "mantle introspect",
    "emit-openapi": "node scripts/mantle.mjs emit-openapi --output openapi.json",
    "emit-types": "node scripts/mantle.mjs emit-types --namespace BlankCms --output mantle-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "pnpm validate:deploy && pnpm typecheck && wrangler deploy"
  },
  "dependencies": {
    "@aotter/mantle": "0.0.11-alpha.35",
    "@cloudflare/workers-oauth-provider": "catalog:",
    "aws4fetch": "catalog:",
    "better-auth": "catalog:",
    "clsx": "catalog:",
    "hono": "catalog:",
    "lucide": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aotter/mantle-spec": "0.0.11-alpha.35",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
