{
  "name": "mantle-starter-publication",
  "version": "0.0.11-alpha.26",
  "private": true,
  "description": "Reference publication starter for mantle v0.1.0 — owner-published content (articles / pages / docs-lite). Optional contact form behavior is installed through the contact feature overlay. Runs on wrangler dev with local D1 + KV.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/wrangler-dev.mjs",
    "fixture": "tsx test/fixture/apply-dev.ts",
    "test:integration": "node scripts/run-integration.mjs",
    "mcp-smoke": "tsx test/integration/mcp-smoke.ts",
    "view-smoke": "tsx test/integration/view-rest-smoke.ts",
    "validate": "mantle validate",
    "validate:deploy": "mantle validate --phase deploy",
    "mantle:update": "node scripts/update.mjs",
    "introspect": "mantle introspect",
    "emit-openapi": "node scripts/mantle.mjs emit-openapi --output openapi.json",
    "emit-types": "node scripts/mantle.mjs emit-types --namespace PublicationCms --output mantle-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "pnpm validate:deploy && pnpm typecheck && wrangler deploy",
    "setup:site": "node scripts/setup-site.mjs",
    "provision:plan": "node scripts/provision.mjs plan",
    "provision:up": "node scripts/provision.mjs up"
  },
  "dependencies": {
    "@aotter/mantle": "0.0.11-alpha.26",
    "@cloudflare/workers-oauth-provider": "catalog:",
    "aws4fetch": "catalog:",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "marked": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aotter/mantle-spec": "0.0.11-alpha.26",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
