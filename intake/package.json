{
  "name": "mantle-starter-intake",
  "version": "0.0.11-alpha.22",
  "private": true,
  "description": "Intake starter for mantle v0.1.0 — publication shape (landing + articles + contact) plus a structured `leads` Schema with leads-recent View and CAPTCHA + Slack-notify lifecycle. Runs on wrangler dev with local D1 + KV.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/wrangler-dev.mjs",
    "fixture": "tsx test/fixture/apply-dev.ts",
    "test:integration": "node scripts/run-integration.mjs",
    "mcp-smoke": "tsx test/integration/mcp-smoke.ts",
    "view-smoke": "tsx test/integration/view-rest-smoke.ts",
    "validate": "mantle validate",
    "validate:deploy": "mantle validate --phase deploy",
    "mantle:prompt": "node scripts/mantle.mjs prompt",
    "mantle:update": "node scripts/update.mjs",
    "introspect": "mantle introspect",
    "emit-openapi": "node scripts/mantle.mjs emit-openapi --output openapi.json",
    "emit-types": "node scripts/mantle.mjs emit-types --namespace IntakeCms --output mantle-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "pnpm validate:deploy && pnpm typecheck && wrangler deploy",
    "setup:site": "node scripts/setup-site.mjs",
    "provision:plan": "node scripts/provision.mjs plan",
    "provision:up": "node scripts/provision.mjs up",
    "theme:fork": "node scripts/theme-fork.mjs",
    "theme:reset": "node scripts/theme-reset.mjs"
  },
  "dependencies": {
    "@aotter/mantle": "0.0.11-alpha.22",
    "@cloudflare/workers-oauth-provider": "catalog:",
    "aws4fetch": "catalog:",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "marked": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aotter/mantle-spec": "0.0.11-alpha.22",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
