{
  "name": "@aotterclam/create-clam-mantle",
  "version": "0.0.10-alpha.1",
  "description": "npx scaffolder for clam-mantle consumer projects. Fetches the starters-monorepo tarball at a runtime-resolved sources.json, merges _common/ + <archetype>/ + (optional) themes/<theme>/ into the user's directory, fills {{PLACEHOLDER}} macros, and prints RUN_NOTES JSON for the Mantle install skill.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/clam-mantle-starters/tree/main/packages/create-clam-mantle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/clam-mantle-starters.git",
    "directory": "packages/create-clam-mantle"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-clam-mantle": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sources": {
      "types": "./dist/sources.d.ts",
      "import": "./dist/sources.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
