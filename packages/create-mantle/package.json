{
  "name": "@aotter/create-mantle",
  "version": "0.0.11-alpha.32",
  "description": "npx scaffolder for blank-first Mantle projects. Fetches sources.json, installs the blank base, records type intent, and includes post-launch overlays.",
  "license": "MIT",
  "private": true,
  "homepage": "https://mantle.tools/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle-starters.git",
    "directory": "packages/create-mantle"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-mantle": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sources": {
      "types": "./dist/sources.d.ts",
      "import": "./dist/sources.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
