{
  "name": "@aotter/mantle-publication-baseline",
  "version": "0.0.11-alpha",
  "description": "Hono+JSX baseline UI for the @aotter/mantle publication starter — Header, Footer, PageShell, default templates (post / postList / page / contact / notFound / home), tokens, icons, header runtime JS. Consumers install via a tarball URL attached to a mantle-starters GitHub release; not on npm by policy. Override the L3 component slots (`overrides.components.Header` etc.) or the L4 template slots (`overrides.templates.home` etc.) from your project's `src/theme/index.ts`.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/aotter/mantle-starters/tree/main/packages/publication-baseline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle-starters.git",
    "directory": "packages/publication-baseline"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted",
    "tag": "alpha"
  },
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "import": "./dist/styles.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "hono": "^4.6.20",
    "marked": "^14.1.3"
  },
  "peerDependencies": {
    "@aotter/mantle": ">=0.0.10-alpha"
  },
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@aotter/mantle": "0.0.10-alpha",
    "@types/node": "^20",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
