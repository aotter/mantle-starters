{
  "name": "@aotter/mantle-media-tools",
  "version": "0.0.11-alpha.27",
  "description": "Agent-side helper for mantle multi-variant media uploads (aotter/mantle#272). Takes a source image, produces avif/webp/jpeg variants via sharp, drives the create_media_upload + commit_media_upload lifecycle against a deployed mantle worker. Private — distributed via mantle-starters' GitHub release tarball, not npm.",
  "license": "MIT",
  "private": true,
  "homepage": "https://mantle.tools/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle-starters.git",
    "directory": "packages/mantle-media-tools"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mantle-media-tools": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  }
}
