{
  "name": "mantle-starters",
  "private": true,
  "version": "0.0.11-alpha.36",
  "description": "Workspace root for the @aotter/mantle blank-first starter bundles, type overlays, and vendored Kiwa source.",
  "license": "MIT",
  "homepage": "https://mantle.tools/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle-starters.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "build:provision-bundle": "node scripts/build-provision-bundle.mjs",
    "check:provision-bundle": "node scripts/build-provision-bundle.mjs --check",
    "check:styles": "node blank/scripts/build-styles.mjs --root blank --check",
    "dev:bundle": "node scripts/dev-provision-bundle.mjs",
    "smoke:provision-bundle": "node scripts/smoke-provision-bundle.mjs",
    "check:kiwa": "node scripts/sync-kiwa.mjs --check",
    "check:starter-locks": "node scripts/refresh-starter-locks.mjs --check",
    "check:repo-local-skills": "node scripts/check-repo-local-skills.mjs",
    "check:core-skills": "node scripts/sync-core-skills.mjs --check",
    "check:wrangler-dev": "node scripts/check-wrangler-dev-wrapper.mjs",
    "sync:core-skills": "node scripts/sync-core-skills.mjs",
    "refresh:starter-locks": "node scripts/refresh-starter-locks.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "packageManager": "pnpm@9.15.0"
}
